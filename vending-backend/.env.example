# --- MQTT Configuration ---
# The hostname and port of the Mosquitto broker.
# Within Docker Compose, the hostname is the service name "mosquitto".
MQTT_HOST=mosquitto
MQTT_PORT=1883

# The URL used by the Next.js app to connect to Mosquitto for publishing.
# Within Docker Compose, this should point to the mosquitto service.
MQTT_BROKER_URL=mqtt://mosquitto:1883

# --- MQTT Webhook Security ---
# A shared secret used to authenticate requests from the MQTT bridge
# to the Next.js webhook endpoint. Generate a random string.
MQTT_WEBHOOK_SECRET=your-random-webhook-secret-here

# --- Caddy / Domain Configuration ---
# The domain name for automatic HTTPS via Let's Encrypt.
# Set to "localhost" for local development (disables HTTPS).
DOMAIN=localhost

# --- Next.js ---
# Set to "production" for deployment, "development" for local work.
NODE_ENV=production

# --- Optional: Next.js Webhook URL ---
# Used by the MQTT bridge to forward events to Next.js via HTTP (alternative to direct DB).
# Within Docker Compose, use the service name.
NEXT_APP_URL=http://next-app:3000
