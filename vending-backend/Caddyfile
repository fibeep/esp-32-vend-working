# Caddyfile -- Reverse proxy for the VMFlow Vending Backend
#
# Caddy automatically obtains and renews TLS certificates from Let's Encrypt.
# Replace {$DOMAIN} with your actual domain (e.g. api.vmflow.xyz) or set it
# in the .env file and reference it here.
#
# For development/testing without a domain, replace the site address with
# `:80` or `localhost` to disable automatic HTTPS.

{$DOMAIN:localhost} {
    # Proxy all requests to the Next.js app running on port 3000
    reverse_proxy next-app:3000

    # Enable gzip compression for API responses
    encode gzip

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Access logs
    log {
        output stdout
        format console
    }
}
